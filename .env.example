# ---------------------------------------------------------------------------
# Automated SLA Tracking and Report Generation System - Environment Config
# Copy this file to .env and fill in real values. NEVER commit the real .env
# ---------------------------------------------------------------------------

# Flask
FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=change-this-to-a-long-random-string

# Database
# For development (SQLite) - leave unset to use the built-in default
# (instance/sla_tracker.db relative to the project root), or set an
# absolute path explicitly, e.g.:
# DATABASE_URL=sqlite:////absolute/path/to/automated-sla-tracker/instance/sla_tracker.db
DATABASE_URL=
# For production (PostgreSQL), swap to something like:
# DATABASE_URL=postgresql+psycopg2://sla_user:sla_password@localhost:5432/sla_tracker

# DFIR-IRIS Integration
IRIS_BASE_URL=https://your-iris-instance.example.com
IRIS_API_KEY=replace-with-your-iris-api-key
IRIS_VERIFY_SSL=True
IRIS_TIMEOUT_SECONDS=30

# Scheduler
SYNC_INTERVAL_MINUTES=15
SCHEDULER_ENABLED=True
DAILY_REPORT_ENABLED=False
DAILY_REPORT_HOUR=7

# Timezone
DEFAULT_TIMEZONE=Asia/Karachi

# Email / SMTP (optional for MVP)
EMAIL_NOTIFICATIONS_ENABLED=False
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=sla-tracker@example.com
SMTP_USE_TLS=True

# Report storage
REPORTS_FOLDER=generated_reports
